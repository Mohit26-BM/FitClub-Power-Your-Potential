# --- Local development ---
DATABASE_URL="file:./dev.db"

# --- Production (Render) ---
# DATABASE_URL="file:/data/gym.db"   ← points to the persistent disk

# Generate with: openssl rand -base64 32
# PowerShell: [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
AUTH_SECRET="your-32-char-secret-here"

# App URL — no trailing slash
# Local:
NEXTAUTH_URL="http://localhost:3000"
# Production (replace with your Render URL):
# NEXTAUTH_URL="https://fitclub-gym.onrender.com"
